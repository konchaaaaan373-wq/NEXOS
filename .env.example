# ============================================================
# NEXOS Environment Variables
# Copy to .env.local and fill in the values
# ============================================================

# --- Public ---
NEXT_PUBLIC_SITE_URL=https://nexos.necofindjob.com
NEXT_PUBLIC_CONTACT_EMAIL=contact@necofindjob.com

# --- Database (PostgreSQL via Supabase recommended) ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/nexos
# If using Supabase: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# --- NextAuth.js ---
AUTH_SECRET=  # generate with: openssl rand -base64 32
AUTH_URL=https://nexos.necofindjob.com

# --- S3 Storage (for image uploads) ---
# Can use AWS S3, Supabase Storage, or any S3-compatible service
S3_REGION=ap-northeast-1
S3_BUCKET=nexos-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=           # optional: for Supabase Storage / MinIO
S3_PUBLIC_URL=         # optional: CDN or public bucket URL

# --- Email (Resend) ---
RESEND_API_KEY=        # get from https://resend.com
FROM_EMAIL=NEXOS <noreply@necofindjob.com>

# --- AI (Anthropic Claude) ---
ANTHROPIC_API_KEY=     # get from https://console.anthropic.com
