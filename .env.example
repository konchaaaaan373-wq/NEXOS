# NEXOS Environment Variables
# Copy this file to .env.local and fill in the values

# Public site URL (used for OGP, sitemap, etc.)
NEXT_PUBLIC_SITE_URL=https://nexos.necofindjob.com

# Contact email (used in footer, application forms)
NEXT_PUBLIC_CONTACT_EMAIL=contact@necofindjob.com

# --- Future additions (not needed for MVP) ---
# DATABASE_URL=postgresql://...
# NEXTAUTH_URL=https://nexos.necofindjob.com
# NEXTAUTH_SECRET=your-secret-here
# SUPABASE_URL=https://...
# SUPABASE_ANON_KEY=...
