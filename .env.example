# ============================================================
# NEXOS Environment Variables
# Copy to .env.local and fill in the values
# ============================================================

# --- Public ---
NEXT_PUBLIC_SITE_URL=https://nexos.necofindjob.com
NEXT_PUBLIC_CONTACT_EMAIL=contact@necofindjob.com

# --- Database (Neon PostgreSQL) ---
# Netlify × Neon integration auto-provisions these as NETLIFY_DATABASE_URL / NETLIFY_DATABASE_URL_UNPOOLED.
# netlify.toml maps them to DATABASE_URL / DIRECT_DATABASE_URL at build time.
# For local dev, set these manually:
DATABASE_URL=postgresql://neondb_owner:***@ep-***-pooler.*.neon.tech/neondb?channel_binding=require&sslmode=require
DIRECT_DATABASE_URL=postgresql://neondb_owner:***@ep-***.*.neon.tech/neondb?channel_binding=require&sslmode=require

# --- NextAuth.js ---
AUTH_SECRET=  # generate with: openssl rand -base64 32
AUTH_URL=https://nexos.necofindjob.com

# --- S3 Storage (for image uploads) ---
# Can use AWS S3, Supabase Storage, Cloudflare R2, or any S3-compatible service
S3_REGION=ap-northeast-1
S3_BUCKET=nexos-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=           # optional: for non-AWS services
S3_PUBLIC_URL=         # optional: CDN or public bucket URL

# --- Email (Resend) ---
RESEND_API_KEY=        # get from https://resend.com
FROM_EMAIL=NEXOS <noreply@necofindjob.com>

# --- AI (Anthropic Claude) ---
ANTHROPIC_API_KEY=     # get from https://console.anthropic.com
